# 🔐 ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in your actual credentials
# DO NOT COMMIT .env FILE TO GIT

# ========== TWILIO SMS CREDENTIALS ==========
# Get these from https://www.twilio.com/console
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE=+1234567890

# ========== WEATHER API CREDENTIALS ==========
# Get this from https://openweathermap.org/api
WEATHER_API_KEY=your_openweather_api_key_here

# ========== HOW TO USE ==========
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual credentials in .env
# 3. Keep .env in .gitignore (already configured)
# 4. Set environment variables before running backend:
#
#    PowerShell:
#    $env:TWILIO_SID = "ACxxx..."
#    $env:TWILIO_TOKEN = "xxx..."
#    ./mvnw spring-boot:run
#
#    CMD:
#    set TWILIO_SID=ACxxx...
#    mvnw spring-boot:run
#
#    Linux/Mac:
#    export TWILIO_SID=ACxxx...
#    ./mvnw spring-boot:run
